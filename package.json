{
  "name": "signet-vtt",
  "version": "1.0.0",
  "description": "Signet VTT - A Virtual Tabletop Application",
  "author": "Signet Team",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "build": "tsc && vite build && tsc -p electron && electron-builder",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:5173 && tsc -p electron -w\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "electron-builder"
  },
  "build": {
    "appId": "com.signet.vtt",
    "productName": "Signet VTT",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "src/assets/logo.svg",
      "target": [
        "nsis"
      ]
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "framer-motion": "^12.38.0",
    "howler": "^2.2.4",
    "i18next": "^26.3.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.344.0",
    "peerjs": "^1.5.2",
    "pixi-filters": "^6.1.5",
    "pixi.js": "^8.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-draggable": "^4.5.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.15.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.9",
    "@types/howler": "^2.2.13",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^41.5.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  }
}
